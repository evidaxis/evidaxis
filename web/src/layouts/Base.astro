---
// Self-hosted fonts, latin subset only (CWV: ~10 woff2, latin-only).
// The two LCP faces (Familjen Grotesk 600 display + IBM Plex Sans 400 body)
// are declared in global.css against stable /fonts/ paths so they can be
// <link rel=preload>ed by exact URL; the remaining weights load via @fontsource.
import '@fontsource/familjen-grotesk/latin-400.css';
import '@fontsource/familjen-grotesk/latin-500.css';
import '@fontsource/familjen-grotesk/latin-700.css';
import '@fontsource/familjen-grotesk/latin-400-italic.css';
import '@fontsource/ibm-plex-sans/latin-500.css';
import '@fontsource/ibm-plex-sans/latin-600.css';
import '@fontsource/ibm-plex-sans/latin-400-italic.css';
import '@fontsource/ibm-plex-mono/latin-400.css';
import '@fontsource/ibm-plex-mono/latin-500.css';
import '@fontsource/spectral/latin-400-italic.css';
import '@fontsource/spectral/latin-400.css';
import '../styles/global.css';
import { SNAP_DATE, snapshot } from '../lib/data';

export interface Props {
  title: string;
  description: string;
  canonical: string;            // path, e.g. "/e/e_x/"
  jsonLd?: object | object[];
  ogType?: string;
  ogImage?: string;             // path; defaults to the brand card
  jsonTwin?: string;            // path to the machine-readable JSON twin (entity/snapshot)
  citeAs?: string;              // durable claim-URN for signposting (RFC 8574 cite-as)
}
const { title, description, canonical, jsonLd, ogType = 'website', ogImage = '/og.png', jsonTwin, citeAs } = Astro.props;
const site = 'https://evidaxis.org';
const url = site + canonical;
const blocks = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
const nav = [
  ['/coverage/', 'Coverage'],
  ['/methodology/current/', 'Methodology'],
  [`/snapshots/${SNAP_DATE}/`, 'Snapshot'],
  ['/about/', 'About'],
];
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={url} />
  <meta name="theme-color" content="#f7f7f5" />
  <link rel="preload" href="/fonts/familjen-grotesk-latin-600-normal.woff2" as="font" type="font/woff2" crossorigin="anonymous" />
  <link rel="preload" href="/fonts/ibm-plex-sans-latin-400-normal.woff2" as="font" type="font/woff2" crossorigin="anonymous" />
  <meta property="og:type" content={ogType} />
  <meta property="og:site_name" content="Evidaxis" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={url} />
  <meta property="og:image" content={site + ogImage} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:image" content={site + ogImage} />
  <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large" />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="sitemap" href="/sitemap-index.xml" />
  {jsonTwin && <link rel="alternate" type="application/json" href={jsonTwin} />}
  {citeAs && <link rel="cite-as" href={citeAs} />}
  {blocks.map((b) => (
    <script type="application/ld+json" set:html={JSON.stringify(b)} />
  ))}
</head>
<body>
  <header class="masthead">
    <div class="wrap bar">
      <a href="/" class="brand" aria-label="Evidaxis home">
        <svg class="glyph" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <rect x="2.5" y="2.5" width="19" height="19" rx="5.5" stroke="var(--ink)" stroke-width="1.5"/>
          <path d="M6 18 L18 6" stroke="var(--ink)" stroke-width="1.5" stroke-linecap="round"/>
          <circle cx="7.4" cy="7.4" r="2" fill="var(--velocity)"/>
          <circle cx="16.6" cy="16.6" r="2" fill="var(--citation)"/>
        </svg>
        Evidaxis
      </a>
      <nav class="nav">
        {nav.map(([href, label]) => <a href={href}>{label}</a>)}
      </nav>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <footer>
    <div class="wrap">
      <div class="cols">
        <div>
          <div class="brand" style="font-size:1.05rem;margin-bottom:.5rem">
            <svg class="glyph" viewBox="0 0 24 24" fill="none" aria-hidden="true" style="width:18px;height:18px">
              <rect x="2.5" y="2.5" width="19" height="19" rx="5.5" stroke="var(--ink)" stroke-width="1.5"/>
              <path d="M6 18 L18 6" stroke="var(--ink)" stroke-width="1.5" stroke-linecap="round"/>
              <circle cx="7.4" cy="7.4" r="2" fill="var(--velocity)"/>
              <circle cx="16.6" cy="16.6" r="2" fill="var(--citation)"/>
            </svg>Evidaxis
          </div>
          <p class="muted" style="font-size:.86rem;max-width:30ch">An independent observatory of momentum in open AI systems. Measurements released to the public domain under CC0.</p>
        </div>
        <div>
          <p class="foot-h">Institute</p>
          <a href="/methodology/current/">Methodology</a>
          <a href="/glossary/">Glossary</a>
          <a href="/coverage/">Coverage atlas</a>
          <a href={`/snapshots/${SNAP_DATE}/`}>Latest snapshot</a>
          <a href="/about/">About &amp; integrity</a>
        </div>
        <div>
          <p class="foot-h">Open data</p>
          <a href={`/snapshots/${SNAP_DATE}/snapshot.json`}>Snapshot JSON</a>
          <a href="/llms.txt">llms.txt</a>
          <a href="https://github.com/evidaxis">GitHub</a>
          <a href="/about/#cite">How to cite</a>
        </div>
      </div>
      <p class="mono muted" style="font-size:.72rem;margin-top:2rem;border-top:1px solid var(--hairline);padding-top:1rem">
        Evidaxis · methodology {snapshot.methodology_version} · snapshot {snapshot.snapshot_id} · data CC0-1.0 · code Apache-2.0 · independent observatory · © 2026
      </p>
    </div>
  </footer>
</body>
</html>
