---
/**
 * RESERVE — axis alpha vs cohort. Honest reserved state with the real reason from
 * derived.ts (cohort N too small for regression, power ~0). No fabricated number.
 */
import { alpha } from '../../lib/derived';
import SnapshotProvenance from './SnapshotProvenance.astro';
const sig = alpha();
---
<figure class="evchart reserved-sig" role="note" aria-label={`axis alpha reserved: ${sig.reason}`}>
  <div class="rhead">
    <span class="rname mono">axis alpha vs cohort</span>
    <span class="rtag mono">reserved</span>
  </div>
  <p class="rreason">reserved: {sig.reason}</p>
  <figcaption class="chart-cap">
    <dl class="chart-dl">
      <div><dt>status</dt><dd><data value="reserved">reserved</data></dd></div>
      <div><dt>value</dt><dd>insufficient data</dd></div>
    </dl>
    <SnapshotProvenance />
  </figcaption>
</figure>
<style>
  .reserved-sig { color: var(--ink); border: 1px dashed var(--hairline-2); border-radius: 10px; padding: 12px 14px;
    background: color-mix(in srgb, var(--surface-2) 35%, transparent); }
  .reserved-sig .rhead { display: flex; align-items: center; justify-content: space-between; gap: 8px; }
  .reserved-sig .rname { font-size: 10px; letter-spacing: .07em; text-transform: uppercase; color: var(--ink-soft); }
  .reserved-sig .rtag { font-size: 9px; letter-spacing: .1em; text-transform: uppercase; color: var(--ink-mute);
    border: 1px solid var(--hairline-2); border-radius: 999px; padding: 1px 8px; }
  .reserved-sig .rreason { margin: 8px 0 0; font-size: 12px; color: var(--ink-soft); line-height: 1.45; }
</style>
