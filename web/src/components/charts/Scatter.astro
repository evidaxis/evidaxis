---
/**
 * Convergence scatter over ALL entities.
 *   x = a1.cohort_z (velocity), y = a2.cohort_z (citation, NULL-SAFE),
 *   r = momentum, ring if status === 'rising', color by cohort.
 * Rising quadrant (upper-right of the cohort medians, i.e. both z >= 0) gets a
 * wash. 0 rising -> no riser rings, the empty rising quadrant is still drawn and
 * labelled. Null citation_z -> plotted on a dedicated "no citation axis" rail
 * below the plane (honest), never at a fake y.
 */
import { scaleLinear } from '../../lib/charts';
import { entities as allEntities } from '../../lib/data';
import type { Entity } from '../../lib/data';
import { cohortColor, cohortLabel, COHORT_ORDER, fmtZsafe } from '../../lib/cohorts';

export interface Props {
  entities?: Entity[];
  width?: number;
  height?: number;
  dom?: number;            // axis half-domain in z (default 2)
}
const { entities = allEntities, width = 560, height = 420, dom = 2 } = Astro.props;

const m = { t: 22, r: 22, b: 56, l: 52 };
const iw = width - m.l - m.r;
const ih = height - m.t - m.b;
const railH = 24;          // null-citation rail height below the plane
const planeH = ih - railH;

const sx = scaleLinear([-dom, dom], [m.l, m.l + iw]);
const sy = scaleLinear([-dom, dom], [m.t + planeH, m.t]);

const x0 = sx(0), y0 = sy(0);
const momenta = entities.map((e) => e.momentum ?? 0);
const maxMom = Math.max(1, ...momenta);
const rOf = (mom: number | null) => 4 + 7 * Math.sqrt((mom ?? 0) / maxMom);

const withCit = entities.filter((e) => e.axes.openalex_citation_momentum.cohort_z != null);
const noCit = entities.filter((e) => e.axes.openalex_citation_momentum.cohort_z == null);
const risingCount = entities.filter((e) => e.status === 'rising').length;
const ticks = [-2, -1, 1, 2];
const titleId = `sc-t-${Math.random().toString(36).slice(2, 8)}`;
const descId = `sc-d-${Math.random().toString(36).slice(2, 8)}`;

const cohortCount = (key: string) => entities.filter((e) => e.cohort === key).length;
---
<figure class="evchart">
  <svg width={width} height={height} viewBox={`0 0 ${width} ${height}`} role="img" aria-labelledby={`${titleId} ${descId}`}>
    <title id={titleId}>Convergence scatter, velocity z by citation z</title>
    <desc id={descId}>
      {entities.length} systems plotted by development-velocity z (horizontal) and citation-momentum z (vertical).
      {risingCount} in the rising quadrant (both axes above the cohort median).
      {noCit.length} have no citation axis and sit on the lower rail.
    </desc>

    {/* rising quadrant wash (both z >= 0) */}
    <rect x={x0} y={m.t} width={(m.l + iw) - x0} height={y0 - m.t} class="rise-wash" />

    {/* median axes */}
    <line x1={x0} y1={m.t} x2={x0} y2={m.t + planeH} stroke="var(--grid)" stroke-width="1" />
    <line x1={m.l} y1={y0} x2={m.l + iw} y2={y0} stroke="var(--grid)" stroke-width="1" />

    {/* gridlines at +/-1, +/-2 */}
    {ticks.map((g) => (
      <>
        <line x1={sx(g)} y1={m.t} x2={sx(g)} y2={m.t + planeH} stroke="var(--hairline)" stroke-width="0.8" stroke-dasharray="2 3" />
        <line x1={m.l} y1={sy(g)} x2={m.l + iw} y2={sy(g)} stroke="var(--hairline)" stroke-width="0.8" stroke-dasharray="2 3" />
        <text x={sx(g)} y={m.t + planeH + 11} text-anchor="middle" font-size="7" fill="var(--ink-mute)" class="svgtxt">{g > 0 ? '+' : ''}{g}</text>
        <text x={m.l - 6} y={sy(g) + 2.5} text-anchor="end" font-size="7" fill="var(--ink-mute)" class="svgtxt">{g > 0 ? '+' : ''}{g}</text>
      </>
    ))}

    {/* rising-quadrant label */}
    <text x={m.l + iw - 4} y={m.t + 11} text-anchor="end" font-size="8.5" fill="var(--velocity)" letter-spacing=".06em" class="svgtxt">
      RISING QUADRANT{risingCount === 0 ? ' · empty' : ''}
    </text>
    <text x={m.l + 4} y={m.t + planeH - 4} font-size="7" fill="var(--ink-mute)" class="svgtxt">cohort median</text>

    {/* axis titles */}
    <text x={m.l + iw} y={m.t + planeH + 26} text-anchor="end" font-size="8.5" fill="var(--ink-soft)" class="svgtxt">development velocity z &rarr;</text>
    <text transform={`rotate(-90)`} x={-(m.t)} y={11} text-anchor="end" font-size="8.5" fill="var(--ink-soft)" class="svgtxt">citation momentum z &uarr;</text>

    {/* dual-axis points */}
    {withCit.map((e) => {
      const px = sx(Math.max(-dom, Math.min(dom, e.axes.github_commit_velocity.cohort_z ?? 0)));
      const py = sy(Math.max(-dom, Math.min(dom, e.axes.openalex_citation_momentum.cohort_z as number)));
      const c = cohortColor(e.cohort);
      const rr = rOf(e.momentum);
      return (
        <>
          {e.status === 'rising' && <circle cx={px} cy={py} r={rr + 4} fill="none" stroke={c} stroke-width="1.3" opacity="0.45" />}
          <circle cx={px} cy={py} r={rr} fill={c} fill-opacity="0.9" stroke="var(--surface)" stroke-width="1.3">
            <title>{e.name}: velocity z {fmtZsafe(e.axes.github_commit_velocity.cohort_z)}, citation z {fmtZsafe(e.axes.openalex_citation_momentum.cohort_z)}, momentum {e.momentum ?? 'n/a'}</title>
          </circle>
        </>
      );
    })}

    {/* null-citation rail */}
    <line x1={m.l} y1={m.t + planeH + railH - 1} x2={m.l + iw} y2={m.t + planeH + railH - 1} stroke="var(--hairline-2)" stroke-width="0.8" stroke-dasharray="1 3" />
    <text x={m.l} y={m.t + planeH + railH + 9} font-size="7" fill="var(--ink-mute)" class="svgtxt">no citation axis ({noCit.length})</text>
    {noCit.map((e) => {
      const px = sx(Math.max(-dom, Math.min(dom, e.axes.github_commit_velocity.cohort_z ?? 0)));
      const py = m.t + planeH + railH / 2;
      const c = cohortColor(e.cohort);
      return (
        <circle cx={px} cy={py} r={rOf(e.momentum)} fill={c} fill-opacity="0.32" stroke={c} stroke-width="1" stroke-dasharray="2 2">
          <title>{e.name}: velocity z {fmtZsafe(e.axes.github_commit_velocity.cohort_z)}, citation axis absent, momentum {e.momentum ?? 'n/a'}</title>
        </circle>
      );
    })}
  </svg>

  <figcaption class="chart-cap">
    <dl class="chart-dl">
      <div><dt>systems</dt><dd><data value={String(entities.length)}>{entities.length}</data></dd></div>
      <div><dt class="teal">rising</dt><dd class="teal"><data value={String(risingCount)}>{risingCount}</data></dd></div>
      <div><dt>dual-axis</dt><dd><data value={String(withCit.length)}>{withCit.length}</data></dd></div>
      <div><dt>velocity-only</dt><dd><data value={String(noCit.length)}>{noCit.length}</data></dd></div>
      {COHORT_ORDER.map((k) => (
        <div><dt class={`c${COHORT_ORDER.indexOf(k) + 1}`}>{cohortLabel(k)}</dt><dd><data value={String(cohortCount(k))}>{cohortCount(k)}</data></dd></div>
      ))}
    </dl>
  </figcaption>

  <details class="chart-data">
    <summary>Full data, {entities.length} systems</summary>
    <table>
      <thead><tr><th>System</th><th>Cohort</th><th class="num">Velocity z</th><th class="num">Citation z</th><th class="num">Momentum</th><th>Status</th></tr></thead>
      <tbody>
        {entities.map((e) => (
          <tr>
            <td>{e.name}</td>
            <td>{cohortLabel(e.cohort)}</td>
            <td class="num"><data value={String(e.axes.github_commit_velocity.cohort_z)}>{fmtZsafe(e.axes.github_commit_velocity.cohort_z)}</data></td>
            <td class="num">{e.axes.openalex_citation_momentum.cohort_z != null
              ? <data value={String(e.axes.openalex_citation_momentum.cohort_z)}>{fmtZsafe(e.axes.openalex_citation_momentum.cohort_z)}</data>
              : <span class="muted">no axis</span>}</td>
            <td class="num">{e.momentum != null ? <data value={String(e.momentum)}>{e.momentum}</data> : <span class="muted">n/a</span>}</td>
            <td>{e.status}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </details>
</figure>
