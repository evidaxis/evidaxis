---
/**
 * Entity catalog table over the snapshot. Every row is SERVER-RENDERED (real <table>,
 * crawlable by Google + LLMs with no JS). Default HTML source order is cohort, then
 * alphabetical (no ordinal ranking; constitution: reader sorts for themselves).
 * Momentum VALUE is displayed as a measurement. An optional JS-only "sort by momentum"
 * toggle (default OFF) reorders existing <tr> nodes without changing source order
 * for non-JS consumers. Null citation axis renders "no axis", never a fake z.
 */
import { entities as allEntities, commitSeries } from '../lib/data';
import type { Entity } from '../lib/data';
import { cohortColor, cohortLabel, COHORT_ORDER, fmtZsafe } from '../lib/cohorts';
import Sparkline from './Sparkline.astro';

export interface Props {
  entities?: Entity[];
  title?: string;
  limit?: number;
}
const { entities = allEntities, title = 'Catalog', limit } = Astro.props;

const cohortIdx = (key: string) => {
  const i = COHORT_ORDER.indexOf(key);
  return i < 0 ? 999 : i;
};

// Default order: cohort (canonical order), then alphabetical by name. No ordinals.
const catalog = [...entities]
  .sort((a, b) => {
    const c = cohortIdx(a.cohort) - cohortIdx(b.cohort);
    if (c !== 0) return c;
    return a.name.localeCompare(b.name, 'en', { sensitivity: 'base' });
  })
  .slice(0, limit ?? entities.length);

const zClass = (z: number | null, cit = false) =>
  z == null ? 'zn' : z >= 0 ? (cit ? 'zp cit' : 'zp') : 'zn';
const sparkColor = (e: Entity) => {
  const vz = e.axes.github_commit_velocity.cohort_z;
  const cz = e.axes.openalex_citation_momentum.cohort_z;
  return cz != null && vz != null && cz > vz ? 'var(--citation)' : 'var(--velocity)';
};
---
<div class="rank-wrap">
  <div class="rank-top">
    <span class="t">{title} · snapshot</span>
    <label class="mom-toggle">
      <input type="checkbox" data-mom-toggle />
      <span>Sort by momentum</span>
    </label>
  </div>
  <div class="rank-scroll">
    <table class="tbl" data-entitytable>
      <thead>
        <tr>
          <th>System</th>
          <th>Cohort</th>
          <th class="num">Velocity z</th>
          <th class="num">Citation z</th>
          <th class="num">Momentum</th>
          <th>Status</th>
          <th class="sp">Commits</th>
        </tr>
      </thead>
      <tbody>
        {catalog.map((e) => {
          const vz = e.axes.github_commit_velocity.cohort_z;
          const cz = e.axes.openalex_citation_momentum.cohort_z;
          return (
            <tr
              data-coh-idx={cohortIdx(e.cohort)}
              data-sys={e.name.toLowerCase()}
              data-mo={e.momentum ?? -1}
            >
              <td class="sys"><a href={`/e/${e.entity_id}/`}>{e.name}</a></td>
              <td class="coh"><span class="cdot" style={`background:${cohortColor(e.cohort)}`}></span>{cohortLabel(e.cohort)}</td>
              <td class={`z num ${zClass(vz)}`}><data value={String(vz ?? '')}>{fmtZsafe(vz)}</data></td>
              <td class={`z num ${zClass(cz, true)}`}><data value={String(cz ?? '')}>{fmtZsafe(cz)}</data></td>
              <td class="mo num">{e.momentum != null ? <data value={String(e.momentum)}>{e.momentum}</data> : <span class="muted">n/a</span>}</td>
              <td><span class={`badge ${e.status}`}>{e.status}</span></td>
              <td class="sp"><Sparkline values={commitSeries(e.entity_id)} color={sparkColor(e)} width={120} height={26} /></td>
            </tr>
          );
        })}
      </tbody>
    </table>
  </div>
  <div class="rank-foot">Default order: cohort, then alphabetical. Momentum is a within-pilot percentile of the combined signal (a measurement, not a placement). Cohort-normalized z-scores · status follows the two-axis gate · "no axis" = no measurable citation series yet. Sort-by-momentum is optional client-side only.</div>
</div>

<script>
  // Progressive enhancement: optional momentum sort. Default OFF keeps HTML source
  // order (cohort then alphabetical) for crawlers and no-JS readers.
  document.querySelectorAll('.rank-wrap').forEach((wrap) => {
    const table = wrap.querySelector('table[data-entitytable]') as HTMLTableElement | null;
    const toggle = wrap.querySelector('input[data-mom-toggle]') as HTMLInputElement | null;
    const tbody = table?.querySelector('tbody');
    if (!table || !toggle || !tbody) return;

    const sourceOrder = Array.from(tbody.querySelectorAll('tr')) as HTMLElement[];

    const apply = () => {
      const rows = Array.from(tbody.querySelectorAll('tr')) as HTMLElement[];
      if (toggle.checked) {
        rows.sort((a, b) => parseFloat(b.dataset.mo ?? '-1') - parseFloat(a.dataset.mo ?? '-1'));
        rows.forEach((r) => tbody.appendChild(r));
      } else {
        sourceOrder.forEach((r) => tbody.appendChild(r));
      }
    };
    toggle.addEventListener('change', apply);
  });
</script>

<style>
  .rank-wrap { margin-top: 40px; background: var(--surface); border: 1px solid var(--hairline); border-radius: 12px; box-shadow: var(--shadow-card); overflow: hidden; }
  .rank-top { display: flex; justify-content: space-between; align-items: center; padding: 15px 20px; border-bottom: 1px solid var(--hairline); background: linear-gradient(var(--surface), var(--paper)); gap: 12px; flex-wrap: wrap; }
  .rank-top .t { font-family: var(--font-mono); font-size: 12px; letter-spacing: .08em; text-transform: uppercase; color: var(--ink-soft); }
  .mom-toggle { font-family: var(--font-mono); font-size: 11px; color: var(--ink-mute); display: inline-flex; align-items: center; gap: 7px; cursor: pointer; user-select: none; }
  .mom-toggle input { accent-color: var(--velocity); }
  .rank-scroll { overflow-x: auto; }
  .tbl { width: 100%; border-collapse: collapse; font-size: 14px; }
  .tbl thead th { font-family: var(--font-mono); font-size: 10.5px; letter-spacing: .08em; text-transform: uppercase; color: var(--ink-mute); font-weight: 500; text-align: left; padding: 12px 16px; border-bottom: 1px solid var(--hairline); white-space: nowrap; }
  .tbl thead th.num, .tbl td.num { text-align: right; font-family: var(--font-mono); font-feature-settings: "tnum" 1; }
  .tbl tbody tr { border-bottom: 1px solid var(--hairline); transition: background .14s; }
  .tbl tbody tr:last-child { border-bottom: none; }
  .tbl tbody tr:hover { background: var(--rise-wash); }
  .tbl td { padding: 13px 16px; vertical-align: middle; }
  .tbl .sys { font-family: var(--font-display); font-weight: 600; font-size: 15px; letter-spacing: -.01em; }
  .tbl .sys a { transition: color .15s; }
  .tbl .sys a:hover { color: var(--velocity); }
  .tbl .coh { color: var(--ink-soft); font-size: 13px; white-space: nowrap; }
  .tbl .coh .cdot { width: 8px; height: 8px; border-radius: 50%; display: inline-block; margin-right: 7px; vertical-align: baseline; }
  .tbl .z { font-size: 13px; }
  .tbl .z.zp { color: var(--velocity); }
  .tbl .z.zp.cit { color: var(--citation); }
  .tbl .z.zn { color: var(--ink-mute); }
  .tbl .mo { font-weight: 600; font-size: 14px; }
  .tbl .sp { width: 132px; }
  .tbl .badge { font-size: 10px; }
  .rank-foot { padding: 13px 20px; border-top: 1px solid var(--hairline); font-family: var(--font-mono); font-size: 11.5px; color: var(--ink-mute); background: var(--paper); line-height: 1.5; }
  @media (max-width: 760px) { .tbl { min-width: 640px; } }
</style>
