---
/**
 * Ranking table over the snapshot. Every row is SERVER-RENDERED (real <table>,
 * crawlable by Google + LLMs with no JS) and sorted by momentum desc at build.
 * Column sort is progressive enhancement: an inline script reorders the EXISTING
 * <tr> nodes by reading their data-* keys, it never injects rows. Null citation
 * axis renders an honest "no axis" cell, never a fake z. Cohort labels route
 * through cohortLabel so the em-dash in the raw label never ships.
 */
import { entities as allEntities, commitSeries } from '../lib/data';
import type { Entity } from '../lib/data';
import { cohortColor, cohortLabel, fmtZsafe } from '../lib/cohorts';
import Sparkline from './Sparkline.astro';

export interface Props {
  entities?: Entity[];
  title?: string;
  limit?: number;
}
const { entities = allEntities, title = 'Ranking', limit } = Astro.props;

const STATUS_ORDER: Record<string, number> = { rising: 0, watch: 1, tracked: 2, 'single-axis': 3, calibration: 4 };
const ranked = [...entities]
  .sort((a, b) => (b.momentum ?? -1) - (a.momentum ?? -1))
  .slice(0, limit ?? entities.length);

const zClass = (z: number | null, cit = false) =>
  z == null ? 'zn' : z >= 0 ? (cit ? 'zp cit' : 'zp') : 'zn';
const sparkColor = (e: Entity) => {
  const vz = e.axes.github_commit_velocity.cohort_z;
  const cz = e.axes.openalex_citation_momentum.cohort_z;
  return cz != null && vz != null && cz > vz ? 'var(--citation)' : 'var(--velocity)';
};
---
<div class="rank-wrap">
  <div class="rank-top">
    <span class="t">{title} · snapshot</span>
    <span class="hint">click a column to sort &#8597;</span>
  </div>
  <div class="rank-scroll">
    <table class="tbl" data-ranktable>
      <thead>
        <tr>
          <th data-key="rank" data-type="num" class="num" aria-sort="ascending">#<span class="caret">&#9650;</span></th>
          <th data-key="sys" data-type="str">System<span class="caret">&#8597;</span></th>
          <th data-key="coh" data-type="str">Cohort<span class="caret">&#8597;</span></th>
          <th data-key="vz" data-type="num" class="num">Velocity z<span class="caret">&#8597;</span></th>
          <th data-key="cz" data-type="num" class="num">Citation z<span class="caret">&#8597;</span></th>
          <th data-key="mo" data-type="num" class="num">Momentum<span class="caret">&#8597;</span></th>
          <th data-key="st" data-type="str">Status<span class="caret">&#8597;</span></th>
          <th class="sp">Commits</th>
        </tr>
      </thead>
      <tbody>
        {ranked.map((e, i) => {
          const vz = e.axes.github_commit_velocity.cohort_z;
          const cz = e.axes.openalex_citation_momentum.cohort_z;
          return (
            <tr
              data-rank={i + 1}
              data-sys={e.name.toLowerCase()}
              data-coh={cohortLabel(e.cohort).toLowerCase()}
              data-vz={vz ?? -99}
              data-cz={cz ?? -99}
              data-mo={e.momentum ?? -1}
              data-st={STATUS_ORDER[e.status] ?? 9}
            >
              <td class="rk num">{i + 1}</td>
              <td class="sys"><a href={`/e/${e.entity_id}/`}>{e.name}</a></td>
              <td class="coh"><span class="cdot" style={`background:${cohortColor(e.cohort)}`}></span>{cohortLabel(e.cohort)}</td>
              <td class={`z num ${zClass(vz)}`}><data value={String(vz ?? '')}>{fmtZsafe(vz)}</data></td>
              <td class={`z num ${zClass(cz, true)}`}><data value={String(cz ?? '')}>{fmtZsafe(cz)}</data></td>
              <td class="mo num">{e.momentum != null ? <data value={String(e.momentum)}>{e.momentum}</data> : <span class="muted">n/a</span>}</td>
              <td><span class={`badge ${e.status}`}>{e.status}</span></td>
              <td class="sp"><Sparkline values={commitSeries(e.entity_id)} color={sparkColor(e)} width={120} height={26} /></td>
            </tr>
          );
        })}
      </tbody>
    </table>
  </div>
  <div class="rank-foot">Cohort-normalized z-scores · momentum is a within-pilot percentile of the combined signal · status follows the two-axis gate · "no axis" = no measurable citation series yet.</div>
</div>

<script>
  // Progressive enhancement: reorder EXISTING server-rendered rows on header click.
  document.querySelectorAll('table[data-ranktable]').forEach((table) => {
    const tbody = table.querySelector('tbody');
    if (!tbody) return;
    const ths = Array.from(table.querySelectorAll('thead th[data-key]')) as HTMLElement[];
    ths.forEach((th) => {
      th.tabIndex = 0;
      const run = () => {
        const key = th.dataset.key!;
        const type = th.dataset.type;
        const cur = th.getAttribute('aria-sort');
        const dir = cur === 'ascending' ? 'descending' : 'ascending';
        ths.forEach((o) => { o.removeAttribute('aria-sort'); const c = o.querySelector('.caret'); if (c) c.textContent = '↕'; });
        th.setAttribute('aria-sort', dir);
        const caret = th.querySelector('.caret'); if (caret) caret.textContent = dir === 'ascending' ? '▲' : '▼';
        const rows = Array.from(tbody.querySelectorAll('tr')) as HTMLElement[];
        rows.sort((a, b) => {
          const va = a.dataset[key]!, vb = b.dataset[key]!;
          let c = type === 'num' ? parseFloat(va) - parseFloat(vb) : va < vb ? -1 : va > vb ? 1 : 0;
          return dir === 'ascending' ? c : -c;
        });
        rows.forEach((r) => tbody.appendChild(r));
      };
      th.addEventListener('click', run);
      th.addEventListener('keydown', (ev) => { if (ev.key === 'Enter' || ev.key === ' ') { ev.preventDefault(); run(); } });
    });
  });
</script>

<style>
  .rank-wrap { margin-top: 40px; background: var(--surface); border: 1px solid var(--hairline); border-radius: 12px; box-shadow: var(--shadow-card); overflow: hidden; }
  .rank-top { display: flex; justify-content: space-between; align-items: center; padding: 15px 20px; border-bottom: 1px solid var(--hairline); background: linear-gradient(var(--surface), var(--paper)); }
  .rank-top .t { font-family: var(--font-mono); font-size: 12px; letter-spacing: .08em; text-transform: uppercase; color: var(--ink-soft); }
  .rank-top .hint { font-family: var(--font-mono); font-size: 11px; color: var(--ink-mute); }
  .rank-scroll { overflow-x: auto; }
  .tbl { width: 100%; border-collapse: collapse; font-size: 14px; }
  .tbl thead th { font-family: var(--font-mono); font-size: 10.5px; letter-spacing: .08em; text-transform: uppercase; color: var(--ink-mute); font-weight: 500; text-align: left; padding: 12px 16px; border-bottom: 1px solid var(--hairline); cursor: pointer; user-select: none; white-space: nowrap; transition: color .15s; }
  .tbl thead th:hover { color: var(--ink); }
  .tbl thead th.num, .tbl td.num { text-align: right; font-family: var(--font-mono); font-feature-settings: "tnum" 1; }
  .tbl thead th .caret { opacity: .32; margin-left: 4px; font-size: 9px; }
  .tbl thead th[aria-sort] .caret { opacity: 1; color: var(--velocity); }
  .tbl tbody tr { border-bottom: 1px solid var(--hairline); transition: background .14s; }
  .tbl tbody tr:last-child { border-bottom: none; }
  .tbl tbody tr:hover { background: var(--rise-wash); }
  .tbl td { padding: 13px 16px; vertical-align: middle; }
  .tbl .rk { font-family: var(--font-mono); color: var(--ink-mute); width: 34px; }
  .tbl .sys { font-family: var(--font-display); font-weight: 600; font-size: 15px; letter-spacing: -.01em; }
  .tbl .sys a { transition: color .15s; }
  .tbl .sys a:hover { color: var(--velocity); }
  .tbl .coh { color: var(--ink-soft); font-size: 13px; white-space: nowrap; }
  .tbl .coh .cdot { width: 8px; height: 8px; border-radius: 50%; display: inline-block; margin-right: 7px; vertical-align: baseline; }
  .tbl .z { font-size: 13px; }
  .tbl .z.zp { color: var(--velocity); }
  .tbl .z.zp.cit { color: var(--citation); }
  .tbl .z.zn { color: var(--ink-mute); }
  .tbl .mo { font-weight: 600; font-size: 14px; }
  .tbl .sp { width: 132px; }
  .tbl .badge { font-size: 10px; }
  .rank-foot { padding: 13px 20px; border-top: 1px solid var(--hairline); font-family: var(--font-mono); font-size: 11.5px; color: var(--ink-mute); background: var(--paper); line-height: 1.5; }
  @media (max-width: 760px) { .tbl { min-width: 680px; } }
</style>
