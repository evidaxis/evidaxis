---
import Base from '../../../layouts/Base.astro';
import { industries, entitiesInCohort, snapshot } from '../../../lib/data';
import { breadcrumb } from '../../../lib/jsonld';

export function getStaticPaths() {
  return [...industries().values()].map((ind) => ({
    params: { industry: ind.slug },
    props: { slug: ind.slug, label: ind.label, subs: [...ind.subniches.values()] },
  }));
}
const { slug, label, subs } = Astro.props;
const desc = `Evidaxis coverage of ${label}: ${subs.length} sub-niche cohort(s) of open AI systems, measured by momentum.`;
const SITE = 'https://evidaxis.org';
const listJson = {
  '@context': 'https://schema.org', '@type': 'CollectionPage',
  '@id': `${SITE}/industries/${slug}/#page`, url: `${SITE}/industries/${slug}/`,
  name: `${label} — Evidaxis`, isPartOf: { '@id': `${SITE}/#website` },
  about: { '@type': 'ItemList', name: `${label} sub-niches`, numberOfItems: subs.length,
    itemListElement: subs.map((sn: any, i: number) => ({ '@type': 'ListItem', position: i + 1, url: `${SITE}/industries/${slug}/${sn.slug}/`, name: sn.label })) },
};
const crumbs = breadcrumb([{ name: 'Coverage', path: '/coverage/' }, { name: label, path: `/industries/${slug}/` }]);
---
<Base title={`${label} — Evidaxis`} description={desc} canonical={`/industries/${slug}/`} jsonLd={[listJson, crumbs]}>
  <nav class="wrap mono muted" style="font-size:.74rem;padding-top:1rem"><a href="/coverage/" style="border:none;color:inherit">coverage</a> / <span>{label}</span></nav>
  <section class="section">
    <div class="wrap">
      <p class="eyebrow">Industry</p>
      <h1>{label}</h1>
      <div class="stack" style="margin-top:1.6rem">
        {subs.map((sn) => {
          const es = entitiesInCohort(sn.cohortKey);
          const top = es.filter((e) => e.status === 'rising' || e.status === 'watch').slice(0, 3);
          return (
            <a class="card" href={`/industries/${slug}/${sn.slug}/`}>
              <div class="row" style="justify-content:space-between;align-items:baseline">
                <h3 style="margin:0">{sn.label}</h3>
                <span class="mono muted" style="font-size:.74rem">{es.length} systems</span>
              </div>
              {top.length>0 && <p class="muted" style="font-size:.86rem;margin:.5rem 0 0">Signals: {top.map((e)=>e.name).join(', ')}</p>}
            </a>
          );
        })}
      </div>
    </div>
  </section>
</Base>
