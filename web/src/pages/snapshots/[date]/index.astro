---
import Base from '../../../layouts/Base.astro';
import EntityTable from '../../../components/EntityTable.astro';
import { snapshot, SNAP_DATE, entities, manifest } from '../../../lib/data';
import { snapshotDataset, breadcrumb } from '../../../lib/jsonld';

export function getStaticPaths() {
  return [{ params: { date: SNAP_DATE }, props: {} }];
}
const all = [...entities].sort((a, b) => (b.momentum ?? -1) - (a.momentum ?? -1));
const desc = `Evidaxis snapshot ${SNAP_DATE}: momentum measurements for ${snapshot.counts.entities} AI systems we track, methodology ${snapshot.methodology_version}. Frozen, hash-verified, CC0 open data.`;
---
<Base title={`Snapshot ${SNAP_DATE} | Evidaxis`} description={desc} canonical={`/snapshots/${SNAP_DATE}/`} jsonTwin={`/snapshots/${SNAP_DATE}/snapshot.json`} jsonLd={[snapshotDataset(snapshot), breadcrumb([{ name: 'Snapshots', path: `/snapshots/${SNAP_DATE}/` }])]}>
  <section class="section">
    <div class="wrap">
      <p class="eyebrow">Frozen snapshot</p>
      <h1>Snapshot {SNAP_DATE}</h1>
      <p class="lead" style="max-width:60ch">A frozen record of the measurements we took for the systems we track at period {snapshot.period}. Every input is hash-pinned and the raw provenance is published, so any score is checkable against its hash-pinned inputs. Released to the public domain under CC0 open data: cite it, audit it, check it.</p>

      <div class="meta mono" style="margin:1.2rem 0 1.6rem">
        <span>snapshot_id <b>{snapshot.snapshot_id}</b></span>
        <span>period <b>{snapshot.period}</b></span>
        <span>methodology <b>{snapshot.methodology_version}</b></span>
        <span>schema <b>{snapshot.schema_version}</b></span>
        <span>manifest_hash <b>{manifest.manifest_hash.slice(0,12)}…</b></span>
        <span>license <b>{snapshot.license}</b></span>
        <span>cite this deposit <a href="https://doi.org/10.5281/zenodo.21076012"><b>10.5281/zenodo.21076012</b></a></span>
      </div>

      <div class="row" style="margin-bottom:2rem">
        <a class="badge" href={`/snapshots/${SNAP_DATE}/snapshot.json`} style="text-transform:none;font-size:.82rem;padding:8px 14px">Download snapshot.json ↓</a>
        <a class="badge" href="/methodology/current/" style="text-transform:none;font-size:.82rem;padding:8px 14px">Methodology →</a>
      </div>

      <div class="panel" style="padding:18px 20px;margin-bottom:2rem">
        <div class="eyebrow">Gate</div>
        <p class="mono" style="font-size:.82rem;margin:.5rem 0 0;color:var(--ink-soft)">{snapshot.gate}</p>
      </div>

      <h2 style="font-size:1.4rem">All measured systems</h2>
      <EntityTable entities={all} />
    </div>
  </section>
</Base>
