---
import Base from '../../../layouts/Base.astro';
import { manifestForSnapshot, snapshots } from '../../../lib/data';
import type { Snapshot } from '../../../lib/data';
import { hasSnapshotArtifact } from '../../../lib/archive';
import { snapshotDataset, breadcrumb } from '../../../lib/jsonld';
import { claimUrnForEntity } from '../../../lib/claim_urn';

export function getStaticPaths() {
  return snapshots.map((snapshot) => ({
    params: { date: snapshot.snapshot_date },
    props: { snapshot, manifest: manifestForSnapshot(snapshot.snapshot_date) },
  }));
}
const { snapshot, manifest } = Astro.props as { snapshot: Snapshot; manifest: any | null };
const date = snapshot.snapshot_date;
const all = [...snapshot.entities].sort((a, b) => (b.momentum ?? -1) - (a.momentum ?? -1));
const hasDropped = hasSnapshotArtifact(date, 'dropped.json');
const desc = `Evidaxis snapshot ${date}: momentum measurements for ${snapshot.counts.entities} AI systems, methodology ${snapshot.methodology_version}. Frozen, hash-verified, CC0 open data.`;
const fmt = (n: number | null | undefined, digits = 2) => n == null ? 'n/a' : n.toFixed(digits);
---
<Base title={`Snapshot ${date} | Evidaxis`} description={desc} canonical={`/snapshots/${date}/`} jsonTwin={`/snapshots/${date}/snapshot.json`} jsonLd={[snapshotDataset(snapshot), breadcrumb([{ name: 'Snapshot archive', path: '/snapshots/' }, { name: date, path: `/snapshots/${date}/` }])]}>
  <section class="section">
    <div class="wrap">
      <p class="eyebrow">Frozen snapshot, dated record</p>
      <h1>Snapshot {date}</h1>
      <p class="lead" style="max-width:60ch">A frozen record of measurements taken for period {snapshot.period}. Every score, count, and claim reference below belongs to this dated snapshot.</p>

      <div class="meta mono" style="margin:1.2rem 0 1.6rem">
        <span>snapshot_id <b>{snapshot.snapshot_id}</b></span>
        <span>period <b>{snapshot.period}</b></span>
        <span>methodology <b>{snapshot.methodology_version}</b></span>
        <span>schema <b>{snapshot.schema_version}</b></span>
        {manifest?.manifest_hash && <span>manifest_hash <b>{manifest.manifest_hash.slice(0,12)}…</b></span>}
        <span>entities <b>{snapshot.entities.length}</b></span>
        <span>license <b>{snapshot.license}</b></span>
      </div>

      <div class="row" style="margin-bottom:2rem">
        <a class="badge" href={`/snapshots/${date}/snapshot.json`} style="text-transform:none;font-size:.82rem;padding:8px 14px">Download snapshot.json ↓</a>
        <a class="badge" href="/snapshots/" style="text-transform:none;font-size:.82rem;padding:8px 14px">Snapshot archive →</a>
        <a class="badge" href="/methodology/current/" style="text-transform:none;font-size:.82rem;padding:8px 14px">Methodology →</a>
      </div>

      <div class="panel verify-bundle" style="padding:18px 20px;margin-bottom:2rem">
        <div class="eyebrow">Verification bundle</div>
        <p style="font-size:.9rem;margin:.5rem 0 .9rem;color:var(--ink-soft);max-width:70ch">
          Frozen, hash-pinned inputs for this snapshot. Download the checksums file, then each
          listed artifact, and verify with <span class="mono">sha256sum -c SHA256SUMS</span>.
        </p>
        <ul class="verify-list mono">
          <li><a href={`/snapshots/${date}/manifest.json`}>manifest.json</a> <span class="muted">input pin list</span></li>
          <li><a href={`/snapshots/${date}/provenance.json`}>provenance.json</a> <span class="muted">raw source provenance</span></li>
          <li><a href={`/snapshots/${date}/SHA256SUMS`}>SHA256SUMS</a> <span class="muted">text/plain checksums</span></li>
          {hasDropped && (
            <li><a href={`/snapshots/${date}/dropped.json`}>dropped.json</a> <span class="muted">entities dropped this run</span></li>
          )}
          <li><a href={`/snapshots/${date}/snapshot.json`}>snapshot.json</a> <span class="muted">scored measurements</span></li>
        </ul>
      </div>

      <div class="panel" style="padding:18px 20px;margin-bottom:2rem">
        <div class="eyebrow">Cite</div>
        {date === '2026-06-27' ? (
          <p style="font-size:.9rem;margin:.5rem 0 0;color:var(--ink-soft);max-width:70ch">
            Cite this deposit: DOI <a href="https://doi.org/10.5281/zenodo.21076012">10.5281/zenodo.21076012</a>
            (genesis seed, methodology m1, 19 systems). snapshot_id <span class="mono">{snapshot.snapshot_id}</span>.
          </p>
        ) : (
          <p style="font-size:.9rem;margin:.5rem 0 0;color:var(--ink-soft);max-width:70ch">
            Genesis seed deposit (m1, 19 systems, 2026-06-27): DOI <a href="https://doi.org/10.5281/zenodo.21076012">10.5281/zenodo.21076012</a>.
            Cite <em>this</em> snapshot by its own identity: snapshot_id <span class="mono">{snapshot.snapshot_id}</span>,
            date <span class="mono">{date}</span>, methodology <span class="mono">{snapshot.methodology_version}</span>;
            each system row carries its claim-URN.
            <!-- future per-version DOI slot: mint a Zenodo version DOI for this snapshot and list it here. -->
          </p>
        )}
      </div>

      <div class="panel" style="padding:18px 20px;margin-bottom:2rem">
        <div class="eyebrow">Gate</div>
        <p class="mono" style="font-size:.82rem;margin:.5rem 0 0;color:var(--ink-soft)">{snapshot.gate}</p>
      </div>

      <h2 style="font-size:1.4rem">All measured systems</h2>
      <div class="archive-table-wrap">
        <table class="archive-table">
          <caption>All systems measured in snapshot {date}, with claim-URN per row</caption>
          <thead><tr>
            <th scope="col">System</th>
            <th scope="col">Status</th>
            <th scope="col">Momentum</th>
            <th scope="col">Velocity z</th>
            <th scope="col">Citation z</th>
          </tr></thead>
          <tbody>{all.map((e) => <tr>
            <th scope="row"><a href={`/e/${e.entity_id}/`}><strong>{e.name}</strong></a><small class="mono">{e.entity_id}</small><small class="mono urn">{claimUrnForEntity(e, snapshot)}</small></th>
            <td>{e.status}</td>
            <td>{fmt(e.momentum, 1)}</td>
            <td>{fmt(e.axes?.github_commit_velocity?.cohort_z)}</td>
            <td>{fmt(e.axes?.openalex_citation_momentum?.cohort_z)}</td>
          </tr>)}</tbody>
        </table>
      </div>
    </div>
  </section>
</Base>

<style>
  .panel { background: var(--surface); border: 1px solid var(--hairline); border-radius: 12px; }
  .verify-list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 8px; font-size: .82rem; }
  .verify-list a { font-weight: 500; }
  .verify-list .muted { color: var(--ink-mute); margin-left: .4rem; font-size: .74rem; }
  .archive-table-wrap { overflow-x: auto; border: 1px solid var(--hairline); border-radius: 12px; background: var(--surface); }
  .archive-table { width: 100%; border-collapse: collapse; font-size: .86rem; }
  .archive-table caption { caption-side: top; text-align: left; padding: 12px 14px 4px; font-family: var(--font-mono); font-size: .72rem; color: var(--ink-mute); }
  th, td { padding: 12px 14px; text-align: left; border-bottom: 1px solid var(--hairline); vertical-align: top; }
  thead th { font-family: var(--font-mono); font-size: .68rem; text-transform: uppercase; color: var(--ink-mute); font-weight: 500; }
  tbody th { font-weight: 400; }
  tbody tr:last-child td, tbody tr:last-child th { border-bottom: 0; }
  th small, td small { display: block; color: var(--ink-mute); margin-top: 3px; }
  th .urn, td .urn { font-size: .62rem; word-break: break-all; }
</style>
