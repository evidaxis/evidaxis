---
import Base from '../../layouts/Base.astro';
import { latest, snapshots } from '../../lib/data';
import { breadcrumb } from '../../lib/jsonld';

const rows = [...snapshots].reverse();
const desc = `Every frozen Evidaxis measurement snapshot, from genesis through ${latest.snapshot_date}.`;
---
<Base title="Snapshot archive | Evidaxis" description={desc} canonical="/snapshots/" jsonLd={breadcrumb([{ name: 'Snapshot archive', path: '/snapshots/' }])}>
  <section class="section">
    <div class="wrap">
      <p class="eyebrow">Append-only record</p>
      <h1>Snapshot archive</h1>
      <p class="lead" style="max-width:60ch">Every published measurement remains addressable here as a frozen dated record.</p>
      <div class="archive-table-wrap">
        <table>
          <caption>Every published Evidaxis snapshot, newest first</caption>
          <thead><tr>
            <th scope="col">Date</th>
            <th scope="col">Snapshot ID</th>
            <th scope="col">Methodology</th>
            <th scope="col">Entities</th>
            <th scope="col">Record</th>
          </tr></thead>
          <tbody>{rows.map((snap) => <tr>
            <th scope="row"><time datetime={snap.snapshot_date}>{snap.snapshot_date}</time></th>
            <td class="mono">{snap.snapshot_id}</td>
            <td class="mono">{snap.methodology_version}</td>
            <td>{snap.entities.length}</td>
            <td><a href={`/snapshots/${snap.snapshot_date}/`}>Open snapshot →</a></td>
          </tr>)}</tbody>
        </table>
      </div>
    </div>
  </section>
</Base>

<style>
  .archive-table-wrap { margin-top: 1.5rem; overflow-x: auto; border: 1px solid var(--hairline); border-radius: 12px; background: var(--surface); }
  table { width: 100%; border-collapse: collapse; }
  caption { caption-side: top; text-align: left; padding: 12px 15px 4px; font-family: var(--font-mono); font-size: .72rem; color: var(--ink-mute); }
  th, td { padding: 13px 15px; text-align: left; border-bottom: 1px solid var(--hairline); }
  thead th { font-family: var(--font-mono); font-size: .68rem; text-transform: uppercase; color: var(--ink-mute); font-weight: 500; }
  tbody th { font-weight: 500; }
  tbody tr:last-child td, tbody tr:last-child th { border-bottom: 0; }
</style>
