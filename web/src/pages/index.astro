---
import Base from '../layouts/Base.astro';
import CitBars from '../components/charts/CitBars.astro';
import RankTable from '../components/RankTable.astro';
import { snapshot, entities, industries, entitiesInCohort, SNAP_DATE } from '../lib/data';
import { cohortColor, cohortLabel, COHORT_ORDER } from '../lib/cohorts';
import { orgGraph, snapshotDataset } from '../lib/jsonld';

const c = snapshot.counts;
const nCohorts = Object.keys(snapshot.cohorts).length;
const byMom = [...entities].sort((a, b) => (b.momentum ?? -1) - (a.momentum ?? -1));
const hero = byMom.find((e) => e.axes.openalex_citation_momentum.status === 'present') ?? byMom[0];

const cohortDesc: Record<string, string> = {
  'robotics-embodied': 'Policies, simulators and embodied agents.',
  'ai-drug-discovery': 'Structure prediction and molecular modeling.',
  'ai-coding-agents': 'Autonomous coding and software-engineering agents.',
};
const cohortSlug = (key: string) => {
  for (const ind of industries().values())
    for (const sn of ind.subniches.values())
      if (sn.cohortKey === key) return `/ai/cohorts/${sn.slug}/`;
  return '/coverage/';
};

const desc = `Evidaxis: a weekly record of momentum across ${c.entities} open AI systems, scored by the rate of change of their signals. Rising means two axes converging. Open data, CC0.`;
---
<Base
  title="Evidaxis, the longitudinal map of open AI momentum"
  description={desc}
  canonical="/"
  jsonLd={[orgGraph(), snapshotDataset(snapshot)]}
  jsonTwin={`/snapshots/${SNAP_DATE}/snapshot.json`}
>
  <!-- ================= HERO ================= -->
  <section class="hero" style="border-top:none">
    <div class="wrap hero-grid">
      <div>
        <span class="eyebrow rv">Evidaxis · Pilot 2026</span>
        <h1 class="rv">We track open AI systems by momentum, and watch which ones <span class="em">accelerate</span>.</h1>
        <p class="lead rv">We hold a longitudinal record of open AI momentum: every system we track, every week, each input hash-pinned with raw provenance published. Size is never scored. We score the rate of change of public signals, and a system rises only when two independent axes climb together. The baseline comes first. The flare gets recorded against it. Open data, CC0.</p>
        <div class="metastrip mono rv">
          <span><b>{c.entities}</b> systems</span><span class="dot">·</span>
          <span><b>{nCohorts}</b> cohorts</span><span class="dot">·</span>
          <span>snapshot <b>{snapshot.snapshot_id}</b></span><span class="dot">·</span>
          <span>period <b>{snapshot.period}</b></span><span class="dot">·</span>
          <span>methodology <b>{snapshot.methodology_version}</b></span>
        </div>
        <div class="hero-cta rv">
          <a class="ghost" href="/methodology/current/">Read the methodology <span aria-hidden="true">&rarr;</span></a>
          <a class="textlink" href="/coverage/">Coverage atlas <span class="arr" aria-hidden="true">&rarr;</span></a>
          <a class="textlink" href={`/snapshots/${SNAP_DATE}/snapshot.json`}>Download snapshot (JSON) <span aria-hidden="true">&darr;</span></a>
          <a class="textlink" href="https://doi.org/10.5281/zenodo.21076012">genesis seed deposit (m1, 19 systems) <span class="arr" aria-hidden="true">&rarr;</span></a>
        </div>
      </div>

      <div class="stage rv">
        <div class="mock-main">
          <div class="panel float">
            <div class="panel-bar">
              <div class="tl"><i></i><i></i><i></i></div>
              <span class="addr">evidaxis.org / snapshot / {snapshot.snapshot_id} / {hero.name}</span>
              <span class="tag">LIVE</span>
            </div>
            <div class="panel-body">
              <div class="mock-head">
                <span class="mono mock-sys">{hero.name} · citations / year</span>
                <span class="mono mock-axis">cohort {cohortLabel(hero.cohort)}</span>
              </div>
              <CitBars entity={hero} />
            </div>
          </div>
          <div class="statcard sc-1">
            <div class="k">momentum</div>
            <div class="v teal">{hero.momentum ?? 'n/a'}</div>
            <div class="sub">{hero.name} · illustration</div>
          </div>
          <div class="statcard sc-2">
            <div class="k">rising this snapshot</div>
            <div class="v">{c.rising}<span style="font-size:14px;color:var(--ink-mute)"> / {c.entities}</span></div>
            <div class="sub">convergence is rare by design</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ================= 1.0 THE INSTRUMENT (text summary; charts on /coverage) ================= -->
  <section id="methodology">
    <div class="wrap">
      <div class="sec-head"><span class="sec-num rv">1.0, The instrument</span></div>
      <h2 class="rv">Two axes. One gate.</h2>
      <p class="sec-sub rv">Each axis is normalized within its cohort, so &ldquo;rising&rdquo; means rising relative to its peers. Stars and raw size are never scored. The gate publishes recognition only, and recognition only ever points up.</p>

      <div class="axis-list">
        <div class="axis-item rv">
          <span class="axis-chip vel">velocity</span>
          <div><h3>Development velocity</h3><p>The log-slope of commit activity, a fast, leading signal of where work is accelerating.</p></div>
        </div>
        <div class="axis-item rv">
          <span class="axis-chip cit">citation</span>
          <div><h3>Citation momentum</h3><p>The log-slope of yearly citations, a slow, confirming signal that the work is taking hold.</p></div>
        </div>
        <div class="axis-item rv">
          <span class="axis-chip gate">gate</span>
          <div><h3>The convergence gate</h3><p>A system earns the Rising badge only when both axes rise at once. Watch is one axis rising with the other still present; single-axis systems lack a second axis to converge; tracked dual-axis systems are measured for context; calibration anchors are measured, not badged.</p></div>
        </div>
      </div>
      <div class="gate-note rv"><b>Why two axes?</b> Velocity moves first and noisily; citations move late and slowly. Requiring both filters hype from signal, and recognition only ever points up. <a href="/coverage/">Full chart wall on the coverage atlas →</a></div>
    </div>
  </section>

  <!-- ================= 2.0 STATE OF SNAPSHOT + ONE COMPACT TABLE ================= -->
  <section id="snapshot">
    <div class="wrap">
      <div class="sec-head"><span class="sec-num rv">2.0, State of snapshot {snapshot.snapshot_id}</span></div>
      <h2 class="rv">Convergence is rare, and that is the point.</h2>
      <p class="sec-sub rv">The number that matters here is coverage, not the Rising column. We hold {c.entities} systems across {nCohorts} frontiers in period {snapshot.period}, scored every week, each input hash-pinned. {c.rising === 0 ? 'None cross the gate yet' : `${c.rising} cross the gate`}. A fast codebase runs years ahead of its citations, and a genuinely new system has no citation history yet, so convergence stays rare on purpose. Every weekly snapshot deepens the record the next flare gets measured against.</p>

      <div class="stat-row">
        <div class="stat rising rv">
          <div class="top"><span class="label">Rising</span><span class="badge rising">both axes</span></div>
          <div class="num">{c.rising}</div>
          <div class="delta">{c.rising === 0 ? 'no convergence this snapshot, by design' : 'the full badge, velocity + citations'}</div>
        </div>
        <div class="stat watch rv">
          <div class="top"><span class="label">Watch</span><span class="badge watch">one rising</span></div>
          <div class="num">{c.watch}</div>
          <div class="delta">one axis rising, dual-axis present (not single-axis)</div>
        </div>
        <div class="stat tracked rv">
          <div class="top"><span class="label">Tracked</span><span class="badge tracked">context</span></div>
          <div class="num">{c.tracked + c.calibration}</div>
          <div class="delta">tracked + single-axis + calibration, measured for context</div>
        </div>
      </div>

      <!-- Single compact catalog table (no per-row sparklines  -  see /coverage for the chart wall). -->
      <RankTable title="Catalog" showSparks={false} />
    </div>
  </section>

  <!-- ================= 3.0 COVERAGE (compact; full charts on /coverage) ================= -->
  <section id="coverage" class="below-fold">
    <div class="wrap">
      <div class="sec-head"><span class="sec-num rv">3.0, Coverage</span></div>
      <h2 class="rv">{nCohorts} frontiers under watch.</h2>
      <p class="sec-sub rv">Across {nCohorts} cohorts, every score is checkable against its hash-pinned inputs. Each system is normalized only against its own cohort.</p>

      <div class="cohort-cards">
        {COHORT_ORDER.map((k) => {
          const es = entitiesInCohort(k);
          return (
            <a class="cohort rv" href={cohortSlug(k)}>
              <span class="swatch" style={`background:${cohortColor(k)}`}></span>
              <div class="meta">
                <div class="name">{cohortLabel(k)}</div>
                <div class="desc">{cohortDesc[k] ?? ''}</div>
              </div>
              <div class="count">{es.length}<span>SYSTEMS</span></div>
            </a>
          );
        })}
      </div>

      <p style="margin-top:22px"><a class="textlink rv" href="/coverage/">Full coverage atlas, chart wall, and the frontier we are still extending <span class="arr" aria-hidden="true">&rarr;</span></a></p>
    </div>
  </section>
</Base>

<style>
  /* ---- hero ---- */
  .hero { padding: 84px 0 60px; position: relative; overflow: hidden; }
  .hero-grid { display: grid; grid-template-columns: minmax(0,1.02fr) minmax(0,1.18fr); gap: 54px; align-items: center; }
  .hero h1 { font-family: var(--font-display); font-weight: 600; font-size: clamp(2.6rem,5.4vw,4.15rem); line-height: 1.02; letter-spacing: -.03em; margin: 20px 0 0; max-width: 13ch; }
  .hero h1 .em { font-style: italic; font-family: var(--font-serif); font-weight: 400; letter-spacing: -.01em; }
  .lead { font-size: clamp(1rem,1.5vw,1.16rem); color: var(--ink-soft); margin: 24px 0 0; max-width: 46ch; line-height: 1.62; }
  .metastrip { margin-top: 28px; font-family: var(--font-mono); font-size: 12.5px; color: var(--ink-mute); display: flex; flex-wrap: wrap; gap: 6px 14px; align-items: center; }
  .metastrip b { color: var(--velocity); font-weight: 500; }
  .metastrip .dot { opacity: .4; }
  .hero-cta { margin-top: 32px; display: flex; flex-wrap: wrap; gap: 14px 22px; align-items: center; }
  .ghost { font-family: var(--font-mono); font-size: 13.5px; color: var(--ink); border: 1px solid var(--ink); border-radius: 100px; padding: 11px 19px; display: inline-flex; align-items: center; gap: 7px; transition: all .2s; }
  .ghost:hover { background: var(--ink); color: var(--paper); transform: translateY(-1px); }
  .textlink { font-family: var(--font-mono); font-size: 13.5px; color: var(--ink-soft); display: inline-flex; gap: 6px; align-items: center; transition: color .18s; }
  .textlink:hover { color: var(--velocity); }
  .textlink .arr { transition: transform .2s; }
  .textlink:hover .arr { transform: translateX(3px); }
  .stage { position: relative; perspective: 1600px; }
  .mock-main { transform: rotateY(-7deg) rotateX(2deg) rotate(-.6deg); transform-origin: 60% 50%; }
  .mock-head { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 8px; gap: 10px; }
  .mock-sys { font-size: 11px; letter-spacing: .1em; text-transform: uppercase; color: var(--ink-mute); }
  .mock-axis { font-size: 11px; color: var(--velocity); }
  .statcard { position: absolute; background: var(--surface); border: 1px solid var(--hairline); border-radius: 10px; box-shadow: var(--shadow-float); padding: 12px 14px; }
  .statcard .k { font-family: var(--font-mono); font-size: 10px; letter-spacing: .1em; text-transform: uppercase; color: var(--ink-mute); }
  .statcard .v { font-family: var(--font-display); font-weight: 600; font-size: 24px; line-height: 1.05; margin-top: 3px; letter-spacing: -.02em; }
  .statcard .v.teal { color: var(--velocity); }
  .statcard .sub { font-family: var(--font-mono); font-size: 10.5px; color: var(--ink-soft); margin-top: 3px; }
  .sc-1 { top: -26px; left: -30px; animation: floaty 7s ease-in-out infinite; }
  .sc-2 { bottom: -22px; right: -26px; animation: floaty 8s ease-in-out infinite .8s; }
  @keyframes floaty { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-7px); } }
  @media (prefers-reduced-motion: reduce) { .sc-1, .sc-2 { animation: none; } }

  /* ---- instrument ---- */
  .axis-list { display: flex; flex-direction: column; margin-top: 34px; }
  .axis-item { display: grid; grid-template-columns: auto 1fr; gap: 16px; align-items: start; padding: 20px 0; border-top: 1px solid var(--hairline); }
  .axis-item:first-child { border-top: 0; padding-top: 0; }
  .axis-chip { font-family: var(--font-mono); font-size: 11px; letter-spacing: .05em; text-transform: uppercase; padding: 6px 11px; border-radius: 7px; white-space: nowrap; font-weight: 500; align-self: start; }
  .axis-chip.vel { color: var(--velocity); background: var(--rise-wash); border: 1px solid rgba(12,110,99,.25); }
  .axis-chip.cit { color: var(--citation-ink); background: rgba(176,100,28,.08); border: 1px solid rgba(176,100,28,.25); }
  .axis-chip.gate { color: var(--ink-mute); background: var(--paper-2); border: 1px solid var(--hairline); }
  .axis-item h3 { margin: 0 0 4px; font-family: var(--font-display); font-weight: 600; font-size: 1.06rem; letter-spacing: -.01em; }
  .axis-item p { margin: 0; font-size: .95rem; color: var(--ink-soft); }
  .gate-note { margin-top: 26px; font-size: .95rem; color: var(--ink-soft); background: var(--paper-2); border: 1px solid var(--hairline); border-left: 2px solid var(--velocity); border-radius: 0 10px 10px 0; padding: 16px 18px; }
  .gate-note b { color: var(--ink); }

  /* ---- stat cards ---- */
  .stat-row { display: grid; grid-template-columns: repeat(3,1fr); gap: 20px; margin-top: 36px; }
  .stat { background: var(--surface); border: 1px solid var(--hairline); border-radius: 12px; padding: 22px; box-shadow: var(--shadow-card); position: relative; }
  .stat .top { display: flex; justify-content: space-between; align-items: flex-start; gap: 10px; }
  .stat .label { font-family: var(--font-mono); font-size: 11px; letter-spacing: .1em; text-transform: uppercase; color: var(--ink-mute); }
  .stat .num { font-family: var(--font-display); font-weight: 600; font-size: 3.1rem; line-height: 1; letter-spacing: -.04em; margin: 14px 0 0; }
  .stat .delta { font-family: var(--font-mono); font-size: 12px; margin-top: 8px; color: var(--ink-soft); }
  .stat.rising .num { color: var(--velocity); }
  .stat.watch .num { color: var(--citation-ink); }
  .stat.tracked .num { color: var(--ink-soft); }

  /* ---- coverage ---- */
  .below-fold { content-visibility: auto; contain-intrinsic-size: auto 600px; }
  .cohort-cards { display: flex; flex-direction: column; gap: 16px; margin-top: 40px; }
  .cohort { display: flex; align-items: center; gap: 18px; background: var(--surface); border: 1px solid var(--hairline); border-radius: 12px; padding: 18px 22px; box-shadow: var(--shadow-card); transition: transform .2s, box-shadow .2s; }
  .cohort:hover { transform: translateY(-2px); box-shadow: var(--shadow-float); }
  .cohort .swatch { width: 13px; height: 13px; border-radius: 50%; flex: none; }
  .cohort .meta { flex: 1; }
  .cohort .name { font-family: var(--font-display); font-weight: 600; font-size: 1.18rem; letter-spacing: -.01em; }
  .cohort .desc { font-size: .9rem; color: var(--ink-soft); margin-top: 2px; }
  .cohort .count { font-family: var(--font-display); font-weight: 600; font-size: 1.7rem; color: var(--ink); line-height: 1; letter-spacing: -.02em; text-align: right; }
  .cohort .count span { font-family: var(--font-mono); font-size: .62rem; font-weight: 400; color: var(--ink-mute); letter-spacing: .08em; display: block; margin-top: 3px; }

  /* ---- reveal ---- */
  :global(html.js) .rv { opacity: 0; transform: translateY(16px); transition: opacity .6s ease, transform .6s cubic-bezier(.2,.7,.2,1); }
  :global(html.js) .rv.in { opacity: 1; transform: none; }
  @media (prefers-reduced-motion: reduce) { :global(html.js) .rv { opacity: 1; transform: none; transition: none; } }

  /* ---- responsive ---- */
  @media (max-width: 760px) {
    .hero { padding: 40px 0 30px; }
    .hero-grid { grid-template-columns: 1fr; gap: 46px; }
    .stat-row { grid-template-columns: 1fr; }
    .statcard { position: static; margin: 12px 0 0; display: inline-block; animation: none; }
    .mock-main { transform: none; }
  }
</style>

<script>
  // reveal-on-scroll, respects reduced-motion
  const reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const items = Array.from(document.querySelectorAll('.rv'));
  if (reduce || !('IntersectionObserver' in window)) {
    items.forEach((n) => n.classList.add('in'));
  } else {
    const io = new IntersectionObserver((es) => {
      es.forEach((en) => { if (en.isIntersecting) { en.target.classList.add('in'); io.unobserve(en.target); } });
    }, { threshold: .12, rootMargin: '0px 0px -8% 0px' });
    items.forEach((n, i) => { (n as HTMLElement).style.transitionDelay = (Math.min(i, 6) * 45) + 'ms'; io.observe(n); });
  }
</script>
