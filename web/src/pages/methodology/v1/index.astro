---
import Base from '../../../layouts/Base.astro';
import MethodologyBody from '../../../components/MethodologyBody.astro';
import { methodologyGraph } from '../../../lib/jsonld';
const desc = 'Evidaxis Methodology v1 — how momentum is measured: development-velocity and citation-momentum axes, within-cohort robust-z normalization, and the two-axis convergence gate. Frozen and versioned.';
---
<Base title="Methodology v1 — Evidaxis" description={desc} canonical="/methodology/v1/" jsonLd={methodologyGraph('m1', '/methodology/v1/')}>
  <section class="section">
    <div class="wrap">
      <p class="eyebrow">Methodology · v1 (frozen)</p>
      <h1>How Evidaxis measures momentum</h1>
      <MethodologyBody />
      <p class="mono muted" style="font-size:.74rem;margin-top:2rem;border-top:1px solid var(--hairline);padding-top:1rem">
        This is the frozen v1 definition. The current active version is always at
        <a href="/methodology/current/">/methodology/current</a>. Methodology prose is licensed CC-BY-4.0.
      </p>
    </div>
  </section>
</Base>
