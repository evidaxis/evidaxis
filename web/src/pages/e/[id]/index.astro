---
import Base from '../../../layouts/Base.astro';
import EntityCard from '../../../components/EntityCard.astro';
import EntityRow from '../../../components/EntityRow.astro';
import SwingSignal from '../../../components/charts/SwingSignal.astro';
import SharpeSignal from '../../../components/charts/SharpeSignal.astro';
import ChangepointSignal from '../../../components/charts/ChangepointSignal.astro';
import LagSignal from '../../../components/charts/LagSignal.astro';
import AlphaSignal from '../../../components/charts/AlphaSignal.astro';
import GateEtaSignal from '../../../components/charts/GateEtaSignal.astro';
import SignalQuality from '../../../components/charts/SignalQuality.astro';
import SnapshotProvenance from '../../../components/charts/SnapshotProvenance.astro';
import { entityUniverse, commitSeries, industries, entitiesInCohort, deps, depsSeries, backfillSeries, cleanLabel, fmtZ, fmtSlope } from '../../../lib/data';
import type { ArchivedEntity } from '../../../lib/archive';
import { cohortLabel } from '../../../lib/cohorts';
import { entityGraph, breadcrumb } from '../../../lib/jsonld';
import { claimUrnForEntity } from '../../../lib/claim_urn';
import DepsSparkline from '../../../components/charts/DepsSparkline.astro';
import Sparkline from '../../../components/Sparkline.astro';

export function getStaticPaths() {
  return entityUniverse.map((record) => ({ params: { id: record.entity.entity_id }, props: { record } }));
}
const { record } = Astro.props as { record: ArchivedEntity };
const e = record.entity;
const snapshot = record.snapshot;
const isSuperseded = record.recordStatus === 'superseded';
// Null-guard: thin/older-schema historical records may lack axes entirely
// (review 2026-07-10) — a preserved record must render, never crash the build.
const a1 = e.axes?.github_commit_velocity;
const a2 = e.axes?.openalex_citation_momentum;
const cs = isSuperseded ? [] : commitSeries(e.entity_id);
const urn = claimUrnForEntity(e, snapshot);   // durable canonical citation (CLAIM-URN.md)
const dep = isSuperseded ? null : deps.get(e.entity_id) ?? null;    // latest-only side signal
const dSeries = isSuperseded ? [] : depsSeries(e.entity_id);
const bfSeries = isSuperseded ? [] : backfillSeries(e.entity_id);
const bfValues = bfSeries.map((p) => p.value);

const cohortRanked = isSuperseded
  ? snapshot.entities.filter((x) => x.cohort === e.cohort).sort((a, b) => (b.momentum ?? -1) - (a.momentum ?? -1))
  : entitiesInCohort(e.cohort);
const cohortN = cohortRanked.length;
const indLabel = isSuperseded ? cleanLabel(e.industry) : [...industries().values()].find((i) => i.slug === e.industry)?.label ?? e.industry;
const cohortName = cleanLabel(snapshot.cohorts?.[e.cohort]?.label ?? e.sub_niche);
const related = cohortRanked.filter((x) => x.entity_id !== e.entity_id).slice(0, 6);
const crumbs = breadcrumb([
  { name: 'Coverage', path: '/coverage/' },
  { name: indLabel, path: `/ai/fields/${e.industry}/` },
  { name: cohortName, path: `/ai/cohorts/${e.sub_niche}/` },
  { name: e.name, path: `/e/${e.entity_id}/` },
]);

const paperUrl = e.openalex_work_ids?.length ? `https://openalex.org/${e.openalex_work_ids[0]}` : null;

const velRising = e.convergent_axes?.includes('github_commit_velocity') ?? false;
const citRising = e.convergent_axes?.includes('openalex_citation_momentum') ?? false;
let pathToRising: string | null = null;
if (!e.incumbent && e.status !== 'rising') {
  const need: string[] = [];
  if (!velRising) need.push(a1.recent_weekly_commits != null && a1.recent_weekly_commits < 5
    ? 'development velocity to recover (at least 5 commits per week and a positive within-cohort slope)'
    : 'development velocity to turn positive within its cohort');
  if (!citRising) need.push(a2.status === 'absent'
    ? 'a second measurable axis to exist (no academic paper is currently tracked)'
    : a2.status === 'insufficient' ? 'its citation history to mature (at least 3 completed years) and rise'
    : 'citation momentum to turn positive within its cohort');
  pathToRising = need.join('; ');
}

const badgePath = `/badge/${e.entity_id}/${snapshot.period}.svg`;
const badgeMd = `[![Evidaxis: ${e.name}](https://evidaxis.org${badgePath})](https://evidaxis.org/e/${e.entity_id})`;
const desc = `Evidaxis measurement of ${e.name}: momentum ${e.momentum != null ? e.momentum.toFixed(1) : 'n/a'} of 100, status ${e.status}, in the ${e.sub_niche} cohort. Computed on methodology ${snapshot.methodology_version}, snapshot ${snapshot.snapshot_date}.`;
---
<Base title={`${e.name}, Evidaxis measurement`} description={desc} canonical={`/e/${e.entity_id}/`} ogType="article" jsonTwin={`/e/${e.entity_id}.json`} citeAs={urn} jsonLd={[entityGraph(e, snapshot, urn, dep), crumbs]}>
  <section class="section ent-wrap">
    <div class="wrap">
      <nav class="crumb mono" aria-label="Breadcrumb">
        <a href="/coverage/">coverage</a> /
        <a href={`/ai/fields/${e.industry}/`}>{indLabel.toLowerCase()}</a> /
        <a href={`/ai/cohorts/${e.sub_niche}/`}>{cohortLabel(e.cohort)}</a> /
        <span>{e.name}</span>
      </nav>

      {isSuperseded ? (
        <article class="panel preserved-record">
          <p class="preserved-banner">Preserved historical record; last measured {record.lastSeenSnapshot}; status superseded</p>
          <header>
            <p class="eyebrow">Stable entity record</p>
            <h1>{e.name}</h1>
            <p class="mono muted">{e.entity_id} · {cohortName} · {e.entity_type}</p>
          </header>
          <div class="preserved-grid">
            <div><span>Momentum</span><strong>{e.momentum != null ? e.momentum.toFixed(1) : 'n/a'}</strong></div>
            <div><span>Status at measurement</span><strong>{e.status}</strong></div>
            <div><span>Development velocity z</span><strong>{fmtZ(a1?.cohort_z ?? null)}</strong><small>slope {fmtSlope(a1?.slope ?? null)}</small></div>
            <div><span>Citation momentum z</span><strong>{fmtZ(a2?.cohort_z ?? null)}</strong><small>{a2?.status ?? 'n/a'}</small></div>
          </div>
          <div class="preserved-context">
            <h2>Historical context</h2>
            <p>This record preserves the values published in snapshot {record.lastSeenSnapshot}, with its growth history intact. It is not ranked against a later cohort.</p>
            <p class="mono">History series: n/a in this frozen record.</p>
            <p><a href={`https://github.com/${e.github_repo}`}>github.com/{e.github_repo}</a>{e.homepage && <> · <a href={e.homepage}>project homepage</a></>}</p>
          </div>
          {related.length > 0 && <div class="preserved-context">
            <h2>Peers in the last-seen snapshot</h2>
            <ul>{related.map((peer) => <li><a href={`/e/${peer.entity_id}/`}>{peer.name}</a> <span class="mono muted">{peer.status}</span></li>)}</ul>
          </div>}
        </article>
      ) : (<>
      <EntityCard entity={e} />

      <!-- DERIVED SIGNALS band -->
      <section class="derived-band" aria-label="Derived signals">
        <div class="db-head">
          <h2 class="db-t">Derived signals</h2>
          <span class="db-tag mono">second-order reads, computed from the published series</span>
        </div>
        <p class="db-note mono">
          Three signals ship when the commit series is statistically sufficient; the rest are held in a reserved state
          until the data supports them. A reserved signal shows its reason, never a fabricated number.
          <a href="/methodology/current/#derived">How these are computed.</a>
        </p>
        <div class="db-grid">
          <SwingSignal series={cs} />
          <SharpeSignal series={cs} />
          <ChangepointSignal series={cs} />
          <LagSignal />
          <AlphaSignal />
          <GateEtaSignal />
        </div>
        <div class="db-grid db-foot">
          <SignalQuality entity={e} series={cs} />
          <SnapshotProvenance />
        </div>
      </section>

      {bfValues.length >= 2 && (
        <!-- RECONSTRUCTED history. Never presented as captured: separate namespace, hard label. -->
        <div class="panel backfill-panel" data-backfill="1">
          <h2 class="eyebrow sec-h">Reconstructed history</h2>
          <div class="bf-row">
            <Sparkline values={bfValues} color="var(--ink-mute)" width={220} height={40}
                       label={`${e.name} reconstructed weekly commits`} caption={true} unit="commits/wk" />
            <p class="bf-cap mono">
              Weekly commits over the past year, <b>reconstructed from git history</b> (GitHub commit_activity).
              This is <b>reconstructed, not a point-in-time capture</b>. Evidaxis captures the Type-2 signals
              (watchers, issues, dependents) live and never backfills them; those are the moat.
            </p>
          </div>
        </div>
      )}

      {dep && dSeries.length >= 2 && (
        <!-- ADOPTION trend (R0). Point-in-time dependents over snapshots. Displayed, never scored. -->
        <div class="panel adoption-panel">
          <h2 class="eyebrow sec-h">Adoption trend</h2>
          <div class="ad-row">
            <DepsSparkline series={dSeries} label={`${e.name} dependents over time`} />
            <p class="ad-cap mono">
              Downstream packages depending on <b>{dep.system}/{dep.package}</b> (deps.dev), captured point-in-time each snapshot.
              An adoption signal, <b>not part of the momentum score</b>.
            </p>
          </div>
        </div>
      )}

      <!-- VERDICT -->
      <div class="panel verdict-panel">
        <h2 class="eyebrow sec-h">Verdict</h2>
        <p class="verdict-text">
          {e.status === 'rising' && <>Both independent axes are rising within the {cohortLabel(e.cohort)} cohort. <strong>{e.name}</strong> meets the convergence gate.</>}
          {e.status === 'watch' && <><strong>{e.name}</strong> is rising on <strong>{e.convergent_axes.map(a=>a==='github_commit_velocity'?'development velocity':'citation momentum').join(' and ')}</strong>, but a second independent axis has not yet converged. It is on watch.</>}
          {e.status === 'calibration' && <><strong>{e.name}</strong> is a mature incumbent included to calibrate its cohort. It is measured but not badge-eligible.</>}
          {(e.status==='tracked'||e.status==='single-axis') && <><strong>{e.name}</strong> is tracked. No axis is currently rising relative to its cohort{a2.status!=='present' ? ', and it has no second (citation) axis available' : ''}.</>}
        </p>
        {pathToRising && (
          <p class="path-rising mono"><span class="pr-label">Path to Rising:</span> needs {pathToRising}.</p>
        )}
      </div>

      <!-- SOURCES + BADGE -->
      <div class="ent-cols">
        <div class="panel src-panel">
          <h2 class="eyebrow sec-h">Sources</h2>
          <div class="src-list">
            <div><a href={`https://github.com/${e.github_repo}`}>github.com/{e.github_repo}</a> <span class="mono muted src-note">development-velocity axis</span></div>
            {paperUrl && <div><a href={paperUrl}>OpenAlex paper</a> <span class="mono muted src-note">citation-momentum axis{a2.proxy ? ` (proxy: ${a2.proxy})` : ''}</span></div>}
            {e.homepage && <div><a href={e.homepage}>{e.homepage.replace(/^https?:\/\//,'').replace(/\/$/,'')}</a> <span class="mono muted src-note">homepage</span></div>}
          </div>
        </div>
        <div class="panel badge-panel">
          <h2 class="eyebrow sec-h">Embed this badge</h2>
          <div class="badge-img"><img src={badgePath} alt={`Evidaxis ${e.status}, ${e.name}`} width="232" height="56" /></div>
          <pre class="badge-md mono">{badgeMd}</pre>
        </div>
      </div>

      {related.length > 0 && (
        <div class="peers">
          <h2 class="eyebrow sec-h">Others in {cohortLabel(e.cohort)}</h2>
          <div class="peer-list">
            {related.map((r) => <EntityRow entity={r} rank={cohortRanked.findIndex((x) => x.entity_id === r.entity_id) + 1} />)}
          </div>
          <p class="peer-more"><a href={`/ai/cohorts/${e.sub_niche}/`}>Full {cohortLabel(e.cohort)} cohort &rarr;</a></p>
        </div>
      )}
      </>)}

      <!-- RECEIPT -->
      <div class="receipt mono">
        <span>entity_id <b>{e.entity_id}</b></span>
        <span>methodology <b>{snapshot.methodology_version}</b></span>
        <span>snapshot <b>{snapshot.snapshot_id}</b></span>
        <span>period <b>{snapshot.period}</b></span>
        <span><a href={`/e/${e.entity_id}.json`}>record JSON &darr;</a></span>
        <span><a href={`/snapshots/${snapshot.snapshot_date}/`}>source snapshot</a></span>
      </div>
      <p class="cite mono muted">
        Score derived from public data on Evidaxis methodology {snapshot.methodology_version}, never edited by hand. Cite as:
        &ldquo;Evidaxis, {e.name}, entity {e.entity_id}, snapshot {snapshot.period}.&rdquo;
      </p>
      <p class="cite-urn mono muted">
        Durable reference (format-independent): <b>{urn}</b>
      </p>
    </div>
  </section>
</Base>

<style>
  .ent-wrap { padding-top: 2.4rem; }
  .crumb { font-size: .74rem; color: var(--ink-mute); margin-bottom: 1.1rem; }
  .crumb a { color: inherit; } .crumb a:hover { color: var(--velocity); }

  .derived-band { margin-top: 22px; border: 1px solid var(--hairline); border-radius: 14px; background: var(--surface); box-shadow: var(--shadow-card); overflow: hidden; }
  .db-head { display: flex; align-items: baseline; justify-content: space-between; gap: 12px; flex-wrap: wrap; padding: 16px 20px 0; }
  .db-t { margin: 0; font-family: var(--font-display); font-weight: 600; font-size: 1.2rem; letter-spacing: -.01em; }
  h2.sec-h { margin: 0 0 .55rem; }
  .db-tag { font-size: 10.5px; color: var(--ink-mute); }
  .db-note { font-size: 11px; color: var(--ink-soft); line-height: 1.55; padding: 6px 20px 0; max-width: 80ch; }
  .db-note a { color: var(--velocity); }
  .db-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px; background: var(--hairline); margin-top: 16px; }
  .db-grid > :global(figure), .db-grid > :global(div) { background: var(--surface); margin: 0; padding: 14px 16px; }
  .db-foot { grid-template-columns: 2fr 1fr; margin-top: 1px; }
  @media (max-width: 860px) { .db-grid { grid-template-columns: 1fr 1fr; } .db-foot { grid-template-columns: 1fr; } }
  @media (max-width: 560px) { .db-grid { grid-template-columns: 1fr; } }

  .panel { background: var(--surface); border: 1px solid var(--hairline); border-radius: 12px; box-shadow: var(--shadow-card); }
  .verdict-panel { padding: 22px; margin-top: 18px; }
  .adoption-panel { padding: 18px 20px; margin-top: 14px; }
  .adoption-panel .ad-row { display: flex; align-items: center; gap: 16px; flex-wrap: wrap; margin-top: .5rem; }
  .adoption-panel .ad-cap { font-size: .72rem; color: var(--ink-soft); line-height: 1.5; max-width: 52ch; }
  .adoption-panel .ad-cap b { color: var(--ink-soft); }
  .backfill-panel { padding: 18px 20px; margin-top: 14px; border-style: dashed; }
  .backfill-panel .bf-row { display: flex; align-items: center; gap: 16px; flex-wrap: wrap; margin-top: .5rem; }
  .backfill-panel .bf-cap { font-size: .72rem; color: var(--ink-soft); line-height: 1.5; max-width: 52ch; }
  .backfill-panel .bf-cap b { color: var(--ink-soft); }
  .verdict-text { font-size: 1.05rem; margin: .5rem 0 0; max-width: 66ch; line-height: 1.6; }
  .path-rising { font-size: .82rem; margin: .9rem 0 0; color: var(--ink-soft); border-left: 3px solid var(--citation); padding-left: 12px; line-height: 1.55; }
  .path-rising .pr-label { color: var(--citation); }

  .ent-cols { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; margin-top: 14px; }
  @media (max-width: 720px) { .ent-cols { grid-template-columns: 1fr; } }
  .src-panel, .badge-panel { padding: 18px 20px; }
  .src-list { display: flex; flex-direction: column; gap: .5rem; margin-top: .6rem; font-size: .92rem; }
  .src-note { font-size: .7rem; margin-left: 4px; }
  .badge-img { margin: .7rem 0; } .badge-img img { max-width: 100%; height: auto; }
  .badge-md { margin: 0; font-size: .72rem; background: var(--paper); border: 1px solid var(--hairline); border-left: 2px solid var(--citation); border-radius: 0 7px 7px 0; padding: 10px 12px; white-space: pre-wrap; word-break: break-all; color: var(--ink-soft); }

  .peers { margin-top: 1.8rem; }
  .peer-list { margin-top: .7rem; border: 1px solid var(--hairline); border-radius: 12px; overflow: hidden; background: var(--surface); box-shadow: var(--shadow-card); }
  .peer-more { margin: .8rem 0 0; } .peer-more a { color: var(--velocity); }

  .receipt { display: flex; flex-wrap: wrap; gap: 8px 18px; margin-top: 1.8rem; padding-top: 1rem; border-top: 1px solid var(--hairline); font-size: .74rem; color: var(--ink-mute); }
  .receipt b { color: var(--ink-soft); } .receipt a { color: var(--velocity); }
  .cite { font-size: .72rem; margin-top: .8rem; line-height: 1.5; }
  .cite-urn { font-size: .72rem; margin-top: .35rem; line-height: 1.5; word-break: break-all; }
  .cite-urn b { color: var(--ink-soft); }
  .preserved-record { padding: 22px; }
  .preserved-record h1 { margin: .2rem 0; font-family: var(--font-display); }
  .preserved-banner { margin: -22px -22px 22px; padding: 13px 22px; border-bottom: 1px solid var(--hairline); background: var(--paper); color: var(--citation); font-family: var(--font-mono); font-size: .78rem; font-weight: 600; }
  .preserved-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1px; margin-top: 1.4rem; border: 1px solid var(--hairline); border-radius: 10px; overflow: hidden; background: var(--hairline); }
  .preserved-grid > div { display: flex; flex-direction: column; gap: 4px; padding: 14px; background: var(--surface); }
  .preserved-grid span, .preserved-grid small { font-family: var(--font-mono); font-size: .68rem; color: var(--ink-mute); }
  .preserved-grid strong { font-family: var(--font-display); font-size: 1.1rem; }
  .preserved-context { margin-top: 1.4rem; padding-top: 1rem; border-top: 1px solid var(--hairline); }
  .preserved-context h2 { font-size: 1.05rem; }
  @media (max-width: 720px) { .preserved-grid { grid-template-columns: 1fr 1fr; } }
</style>
